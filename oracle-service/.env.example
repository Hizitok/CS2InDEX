# =============================================================================
# CS2InDEX Oracle Service — 环境变量
# cp .env.example .env，填写真实值后启动
# .env 已加入 .gitignore，请勿提交私钥！
# =============================================================================

# ── RPC 节点 ──────────────────────────────────────────────────────────────────
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY

# ── 部署者私钥（Factory owner，与部署时相同的那个密钥）────────────────────────
# 必须是 Factory owner，因为 Factory.updatePrice() 是 onlyOwner
PRIVATE_KEY=0x你的私钥

# ── 合约地址（从部署脚本输出中复制）─────────────────────────────────────────
FACTORY_ADDRESS=0x...    # CS2InDEXFactory 合约地址
ORACLE_ADDRESS=0x...     # IndexOracle 合约地址（Factory.oracle()）

# ── Pool 配置（JSON 数组）────────────────────────────────────────────────────
# 每个条目对应一个 Pool 合约
# pool: Pool 合约地址（Factory.createPool() 的返回值）
# source: 价格数据源标识符（见下方 Available Sources）
POOL_CONFIGS='[
  {
    "name": "CS2 Global Index",
    "pool": "0x...",
    "source": "global-index"
  }
]'

# Available Sources（PriceAggregator 支持的 source 标识符）:
#   global-index  — CS2 全局指数（来自 SkinFlow.gg）
#   knives-index  — CS2 刀具指数
#   rifles-index  — CS2 步枪指数（来自 EsportFire.com）
#   gloves-index  — CS2 手套指数
# 注：真实 API 尚未打通时，自动使用 mock 价格（带 ±2% 随机波动）

# ── 更新频率 ──────────────────────────────────────────────────────────────────
UPDATE_INTERVAL_MINUTES=5

# ── 日志级别 ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production

# ── 价格数据源 API Key（可选，当前 API 尚未要求，留空即可）────────────────────
SKINFLOW_API_KEY=
ESPORTFIRE_API_KEY=
