# =============================================================================
# CS2InDEX 部署环境变量
# 复制此文件为 .env（项目根目录），填写真实值后部署
# .env 已加入 .gitignore，请勿提交私钥！
# =============================================================================

# ── 部署者私钥（必填）────────────────────────────────────────────────────────
PRIVATE_KEY=0x你的私钥

# ── RPC 节点（至少填一个）────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/你的APIKey
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/你的APIKey

# 本地 anvil（默认 http://127.0.0.1:8545，通常不需要改）
# LOCAL_RPC_URL=http://127.0.0.1:8545

# ── 合约验证（可选，不填则跳过 Etherscan 验证）────────────────────────────
ETHERSCAN_API_KEY=你的EtherscanAPIKey

# ── USDC 地址（测试网留空，自动部署 MockUSDC）────────────────────────────────
# 主网真实 USDC:
# USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
# 测试网留空：
# USDC_ADDRESS=

# ── 测试网 MockUSDC mint 数量（单位 USDC，默认 1,000,000）────────────────────
# DEPLOYER_MINT=1000000000000   # 1,000,000 USDC（6位小数）

# ── 是否在部署前跑测试（默认 true，设为 false 可跳过）────────────────────────
# RUN_TESTS=true
